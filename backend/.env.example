PORT=3000

# GitHub Pages 주소. 테스트 중에는 * 가능, 운영 시에는 https://계정명.github.io 로 제한 권장
ALLOWED_ORIGINS=*

# 제출 토큰. HTML의 hidden token 값과 동일해야 함. 비워두면 토큰 검증 생략
SUBMIT_TOKEN=TEST_TOKEN

# Sheet1 신고인 기본값
APPLICANT_NAME=㈜엘지화학(여수)-신학철

# SMTP 설정
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password
MAIL_FROM=your_smtp_user@example.com
MAIL_TO=receiver@example.com
